{
  "suitePath": "suites/longmemeval-ku-10.json",
  "outputDir": "results",
  "trials": 1,
  "topK": 8,
  "answerer": {
    "type": "openai-compatible",
    "model": "glm-5.1",
    "baseUrl": "https://api.z.ai/api/coding/paas/v4/",
    "apiKeyEnv": "Z_AI_API_KEY",
    "temperature": 0,
    "maxTokens": 1024
  },
  "systems": [
    {
      "id": "lobu-agentic",
      "label": "Lobu (agentic supersede)",
      "type": "command",
      "argv": ["python3", "adapters/lobu_agentic_adapter.py"],
      "env": {
        "LOBU_BASE_URL": "http://localhost:8799",
        "LOBU_ORG_SLUG": "local-install",
        "LOBU_API_TOKEN": "$LOBU_API_TOKEN",
        "GEMINI_API_KEY": "$GEMINI_API_KEY",
        "LOBU_STORE": "facts",
        "LOBU_EMBED_WAIT": "45"
      },
      "topK": 8
    }
  ]
}
